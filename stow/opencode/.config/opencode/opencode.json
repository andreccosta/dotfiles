
{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "share": "disabled",
  "lsp": false,
  "formatter": false,
  "snapshot": false,
  "mcp": {
    "linear": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    },
    "sentry": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp"
    }
  },
  "provider": {
   "fireworks-ai": {
    "models": {
      "accounts/fireworks/routers/glm-5-fast": {
        "name": "GLM-5 Fast"
      },
      "accounts/fireworks/routers/kimi-k2p5-turbo": {
        "name": "Kimi K2.5 Turbo"
      },
      "accounts/fireworks/routers/kimi-k2p6-turbo": {
        "name":"Kimi K2.6 Turbo"
      }
    }
   },
    "work": {
      "npm": "@ai-sdk/openai",
      "options": {
        "baseURL": "{env:CODEX_LB_URL}",
        "apiKey": "{env:CODEX_LB_API_KEY}",
        "serviceTier": "priority"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT-5.5",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "variants": {
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "include": [
                "reasoning.encrypted_content"
              ]
            }
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "variants": {
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "include": [
                "reasoning.encrypted_content"
              ]
            }
          },
          "options": {
            "serviceTier": "priority"
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "variants": {
            "xhigh": {
              "reasoningEffort": "xhigh",
              "reasoningSummary": "auto",
              "include": [
                "reasoning.encrypted_content"
              ]
            }
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 400000,
            "input": 272000,
            "output": 128000
          }
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT-5.3 Codex Spark",
          "reasoning": true,
          "tool_call": true,
          "limit": {
            "context": 128000,
            "input": 100000,
            "output": 32000
          }
        }
      }
    }
  },
  "permission": {
    "bash": {
      "rm *": "ask"
    },
    "read": {
      "*": "allow",
      ".*.vars": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny"
    },
    "todoread": "allow",
    "todowrite": "allow"
  }
}
