font-size = 15
font-family = JetBrainsMono Nerd Font
font-style = Regular
background-opacity = 0.90
background-blur = true
background-blur-radius = 20
mouse-hide-while-typing = false
window-save-state = never
window-inherit-font-size = false
macos-option-as-alt = true
scrollback-limit = 100000
unfocused-split-opacity=0.7

custom-shader = ~/.config/ghostty/shaders/cursor_warp.glsl
custom-shader = ~/.config/ghostty/shaders/ripple_cursor.glsl

# theme
theme = TokyoNight

# default window size
window-width = 120
window-height = 30

# update channel
auto-update-channel = stable

# ssh
shell-integration-features = sudo, ssh-terminfo

# binds
keybind = home=csi:H
keybind = end=csi:F
keybind = shift+enter=text:\n
keybind = cmd+enter=unbind

config-file = ?~/.local/ghostty/config
