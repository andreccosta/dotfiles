{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "share": "disabled",
  "lsp": false,
  "formatter": false,
  "mcp": {
    "linear": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.linear.app/mcp"
    }
  },
  "provider": {
    "work": {
      "options": {
        "baseURL": "{env:CODEX_LB_URL}",
        "apiKey": "{env:CODEX_LB_API_KEY}",
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "reasoning": true,
          "options": { "reasoningEffort": "high", "reasoningSummary": "detailed" },
          "limit": { "context": 1050000, "output": 128000 }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "reasoning": true,
          "options": { "reasoningEffort": "high", "reasoningSummary": "detailed" },
          "limit": { "context": 400000, "output": 128000 }
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "reasoning": true,
          "options": { "reasoningEffort": "high", "reasoningSummary": "detailed" },
          "limit": { "context": 272000, "output": 65536 }
        },
        "gpt-5.1-codex-mini": {
          "name": "GPT-5.1 Codex Mini",
          "reasoning": true,
          "options": { "reasoningEffort": "high", "reasoningSummary": "detailed" },
          "limit": { "context": 272000, "output": 65536 }
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT-5.3 Codex Spark",
          "reasoning": true,
          "options": { "reasoningEffort": "xhigh", "reasoningSummary": "detailed" },
          "limit": { "context": 128000, "output": 65536 }
        }
      }
    },
  },
  "permission": {
    "*": "ask",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "read": "allow",
    "task": "allow",
    "skill": "allow",
    "bash": {
      "git *": "ask",
      "bin/rspec *": "allow",
      "bin/standardrb *": "allow",
      "git branch --show-current": "allow",
      "git commit *": "allow",
      "git diff *": "allow",
      "git grep *": "allow",
      "git ls-files *": "allow",
      "git log *": "allow",
      "git remote -v": "allow",
      "git rev-parse *": "allow",
      "git show *": "allow",
      "git status *": "allow",
      "gh pr diff *": "allow",
      "gh pr view *": "allow",
      "command -v *": "allow",
      "find *": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "rg *": "allow",
      "rm *": "ask",
      "sudo *": "deny",
      "which *": "allow"
    },
    "todoread": "allow",
    "todowrite": "allow"
  }
}
