#!/usr/bin/env bash

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in
    /*) ;;
    *) SOURCE="$DIR/$SOURCE" ;;
  esac
done

DOTFILES_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
STOW_DIR="$DOTFILES_DIR/stow"

usage() {
  cat <<'EOF'
Usage: ./dot <command> [package...]

Commands:
  install    Stow the default or specified dotfiles packages into $HOME
  restow     Re-stow the default or specified dotfiles packages into $HOME
  update     Update system packages and mise tools
  macos      Install macOS Brewfile packages and apply macOS defaults
  help       Show this help message
EOF
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

require_command() {
  if ! command_exists "$1"; then
    echo "error: $1 is not installed or not on PATH" >&2
    exit 1
  fi
}

base_packages() {
  cat <<'EOF'
home
agents
ghostty
kanata
nvim
opencode
pi
zed
EOF
}

os_packages() {
  case "$(uname -s)" in
    Darwin)
      cat <<'EOF'
linearmouse
mac-skhd
mac-yabai
EOF
      ;;
    Linux)
      cat <<'EOF'
linux-hypr
linux-waybar
linux-wofi
EOF
      ;;
  esac
}

package_args() {
  {
    base_packages
    os_packages
  } | awk 'NF'
}

selected_packages() {
  if [ "$#" -gt 0 ]; then
    printf '%s\n' "$@"
  else
    package_args
  fi
}

backup_path() {
  local target="$1"
  local backup

  backup="$target.pre-stow-backup-$(date +%Y%m%d%H%M%S)"

  echo "> mv $target $backup"
  mv "$target" "$backup"
}

resolve_link_target() {
  local path="$1"
  local target
  local dir
  local target_dir

  target="$(readlink "$path")"
  case "$target" in
    /*)
      printf '%s\n' "$target"
      ;;
    *)
      dir="$(cd -P "$(dirname "$path")" && pwd)"
      if ! target_dir="$(cd -P "$dir/$(dirname "$target")" 2>/dev/null && pwd)"; then
        return 1
      fi
      printf '%s\n' "$target_dir/$(basename "$target")"
      ;;
  esac
}

has_stow_ancestor() {
  local path="$1"
  local current
  local resolved

  current="$(dirname "$path")"
  while [ "$current" != "$HOME" ] && [ "$current" != "/" ]; do
    if [ -L "$current" ]; then
      if ! resolved="$(resolve_link_target "$current")"; then
        current="$(dirname "$current")"
        continue
      fi
      case "$resolved" in
        "$STOW_DIR"/*)
          return 0
          ;;
      esac
    fi
    current="$(dirname "$current")"
  done

  return 1
}

reconcile_targets() {
  local packages="$1"
  local package
  local src

  reconcile_target() {
    local package="$1"
    local src="$2"
    local rel
    local target
    local resolved
    local child

    rel="${src#"$STOW_DIR/$package"/}"
    target="$HOME/$rel"

    if [ -L "$target" ]; then
      resolved="$(resolve_link_target "$target")"
      case "$resolved" in
        "$STOW_DIR"/*)
          return 0
          ;;
        "$DOTFILES_DIR"/*)
          echo "> rm $target"
          rm -f "$target"
          return 0
          ;;
      esac
    fi

    if has_stow_ancestor "$target"; then
      return 0
    fi

    if [ -f "$target" ] && [ -f "$src" ] && cmp -s "$src" "$target"; then
      echo "> rm $target"
      rm -f "$target"
      return 0
    fi

    if [ -e "$target" ] && ! { [ -d "$src" ] && [ -d "$target" ]; }; then
      backup_path "$target"
      return 0
    fi

    if [ -d "$src" ] && [ ! -e "$target" ]; then
      return 0
    fi

    if [ -d "$src" ]; then
      while IFS= read -r child; do
        reconcile_target "$package" "$child"
      done < <(find "$src" -mindepth 1 -maxdepth 1)
    fi
  }

  while IFS= read -r package; do
    [ -n "$package" ] || continue

    while IFS= read -r src; do
      reconcile_target "$package" "$src"
    done < <(find "$STOW_DIR/$package" -mindepth 1 -maxdepth 1)
  done <<EOF
$packages
EOF
}

run_stow() {
  local mode="$1"
  shift
  local requested_packages=()
  local stow_options=()
  local packages=()
  local stow_command=()
  local package_list
  local package
  local skip_reconcile=0
  require_command stow

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --)
        shift
        requested_packages+=("$@")
        break
        ;;
      -n|--no|--simulate)
        stow_options+=("$1")
        skip_reconcile=1
        ;;
      -*=*)
        stow_options+=("$1")
        ;;
      -*)
        echo "error: unsupported stow option form: $1" >&2
        echo "use --flag=value for options with values" >&2
        exit 1
        ;;
      *)
        requested_packages+=("$1")
        ;;
    esac
    shift
  done

  cd "$DOTFILES_DIR"

  if [ ${#requested_packages[@]} -gt 0 ]; then
    package_list="$(selected_packages "${requested_packages[@]}")"
  else
    package_list="$(selected_packages)"
  fi

  while IFS= read -r package; do
    [ -n "$package" ] || continue
    if [ ! -d "$STOW_DIR/$package" ]; then
      echo "error: unknown package: $package" >&2
      exit 1
    fi
    packages+=("$package")
  done <<EOF
$package_list
EOF

  if [ "$skip_reconcile" -eq 0 ]; then
    reconcile_targets "$package_list"
  fi

  stow_command=(stow "$mode")
  if [ ${#stow_options[@]} -gt 0 ]; then
    stow_command+=("${stow_options[@]}")
  fi
  stow_command+=(-d "$STOW_DIR" -t "$HOME" "${packages[@]}")

  echo "> ${stow_command[*]}"
  "${stow_command[@]}"
}

run_install() {
  run_stow -S "$@"
}

run_restow() {
  run_stow -R "$@"
}

run_update() {
  if [ "$#" -gt 0 ]; then
    echo "error: update does not accept package arguments" >&2
    exit 1
  fi

  require_command mise

  case "$(uname -s)" in
    Darwin)
      require_command brew
      echo "> brew update && brew upgrade"
      brew update && brew upgrade
      ;;
    Linux)
      if command_exists apt-get; then
        require_command sudo
        echo "> sudo apt-get update && sudo apt-get upgrade -y"
        sudo apt-get update && sudo apt-get upgrade -y
      elif command_exists paru; then
        echo "> paru -Syu"
        paru -Syu
      elif command_exists yay; then
        echo "> yay -Syu"
        yay -Syu
      else
        echo "warning: no supported system package manager found for updates (expected apt-get, paru, or yay on Linux)" >&2
      fi
      ;;
  esac

  echo
  echo "> mise up"
  mise up
}

run_macos() {
  if [ "$#" -gt 0 ]; then
    echo "error: macos does not accept package arguments" >&2
    exit 1
  fi

  if [ "$(uname -s)" != "Darwin" ]; then
    echo "error: macos command is only supported on macOS" >&2
    exit 1
  fi

  require_command brew

  echo "> brew bundle --file mac/Brewfile"
  brew bundle --file "$DOTFILES_DIR/mac/Brewfile"

  echo
  echo "> bash mac/set_defaults.sh"
  bash "$DOTFILES_DIR/mac/set_defaults.sh"
}

main() {
  case "${1:-}" in
    install)
      shift
      run_install "$@"
      ;;
    restow)
      shift
      run_restow "$@"
      ;;
    update)
      shift
      run_update "$@"
      ;;
    macos)
      shift
      run_macos "$@"
      ;;
    -h|--help|help|"")
      if [ "$#" -gt 1 ]; then
        echo "error: help does not accept arguments" >&2
        exit 1
      fi
      usage
      ;;
    *)
      echo "error: unknown command: $1" >&2
      echo >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
