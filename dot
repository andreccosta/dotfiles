#!/usr/bin/env bash

set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in
    /*) ;;
    *) SOURCE="$DIR/$SOURCE" ;;
  esac
done

DOTFILES_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
STOW_DIR="$DOTFILES_DIR/stow"

usage() {
  cat <<'EOF'
Usage: ./dot <command>

Commands:
  install    Stow the default dotfiles packages into $HOME
  restow     Re-stow the default dotfiles packages into $HOME
  update     Update Homebrew packages and mise tools
  macos      Install macOS Brewfile packages and apply macOS defaults
  help       Show this help message
EOF
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

require_command() {
  if ! command_exists "$1"; then
    echo "error: $1 is not installed or not on PATH" >&2
    exit 1
  fi
}

base_packages() {
  cat <<'EOF'
home
agents
ghostty
kanata
nvim
opencode
pi
zed
EOF
}

os_packages() {
  case "$(uname -s)" in
    Darwin)
      cat <<'EOF'
linearmouse
mac-skhd
mac-yabai
EOF
      ;;
    Linux)
      cat <<'EOF'
linux-hypr
linux-waybar
linux-wofi
EOF
      ;;
  esac
}

package_args() {
  {
    base_packages
    os_packages
  } | awk 'NF'
}

backup_path() {
  local target="$1"
  local backup

  backup="$target.pre-stow-backup-$(date +%Y%m%d%H%M%S)"

  echo "> mv $target $backup"
  mv "$target" "$backup"
}

resolve_link_target() {
  local path="$1"
  local target
  local dir

  target="$(readlink "$path")"
  case "$target" in
    /*)
      printf '%s\n' "$target"
      ;;
    *)
      dir="$(cd -P "$(dirname "$path")" && pwd)"
      printf '%s\n' "$(cd -P "$dir/$(dirname "$target")" && pwd)/$(basename "$target")"
      ;;
  esac
}

has_stow_ancestor() {
  local path="$1"
  local current
  local resolved

  current="$(dirname "$path")"
  while [ "$current" != "$HOME" ] && [ "$current" != "/" ]; do
    if [ -L "$current" ]; then
      resolved="$(resolve_link_target "$current")"
      case "$resolved" in
        "$STOW_DIR"/*)
          return 0
          ;;
      esac
    fi
    current="$(dirname "$current")"
  done

  return 1
}

reconcile_targets() {
  local package
  local src
  local rel
  local target
  local resolved

  while IFS= read -r package; do
    [ -n "$package" ] || continue

    find "$STOW_DIR/$package" -mindepth 1 | while IFS= read -r src; do
      rel="${src#"$STOW_DIR/$package"/}"
      target="$HOME/$rel"

      if has_stow_ancestor "$target"; then
        continue
      fi

      if [ -L "$target" ]; then
        resolved="$(resolve_link_target "$target")"
        case "$resolved" in
          "$DOTFILES_DIR"/*)
            if [[ "$resolved" != "$STOW_DIR/"* ]]; then
              echo "> rm $target"
              rm -f "$target"
            fi
            ;;
        esac
      elif [ -f "$target" ] && [ -f "$src" ] && cmp -s "$src" "$target"; then
        echo "> rm $target"
        rm -f "$target"
      elif [ -e "$target" ] && ! { [ -d "$src" ] && [ -d "$target" ]; }; then
        backup_path "$target"
      fi
    done
  done <<EOF
$(package_args)
EOF
}

run_stow() {
  local mode="$1"
  local packages=()
  local package
  require_command stow

  cd "$DOTFILES_DIR"

  reconcile_targets

  while IFS= read -r package; do
    [ -n "$package" ] || continue
    packages+=("$package")
  done <<EOF
$(package_args)
EOF

  echo "> stow $mode -d $STOW_DIR -t $HOME ${packages[*]}"
  stow "$mode" -d "$STOW_DIR" -t "$HOME" "${packages[@]}"
}

run_install() {
  run_stow -S
}

run_restow() {
  run_stow -R
}

run_update() {
  require_command mise

  case "$(uname -s)" in
    Darwin)
      require_command brew
      echo "> brew update && brew upgrade"
      brew update && brew upgrade
      ;;
    Linux)
      if command_exists paru; then
        echo "> paru -Syu"
        paru -Syu
      else
        echo "warning: no supported system package manager found for updates (expected paru on Linux)" >&2
      fi
      ;;
  esac

  echo
  echo "> mise up"
  mise up
}

run_macos() {
  if [ "$(uname -s)" != "Darwin" ]; then
    echo "error: macos command is only supported on macOS" >&2
    exit 1
  fi

  require_command brew

  echo "> brew bundle --file mac/Brewfile"
  brew bundle --file "$DOTFILES_DIR/mac/Brewfile"

  echo
  echo "> bash mac/set_defaults.sh"
  bash "$DOTFILES_DIR/mac/set_defaults.sh"
}

main() {
  case "${1:-}" in
    install)
      run_install
      ;;
    restow)
      run_restow
      ;;
    update)
      run_update
      ;;
    macos)
      run_macos
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      echo "error: unknown command: $1" >&2
      echo >&2
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
