#!/usr/bin/env bash

set -euo pipefail

die() {
  echo "Error: $*" >&2
  exit 1
}

repo_root() {
  git rev-parse --show-toplevel 2>/dev/null || die "not in a git repo"
}

trim() {
  printf '%s\n' "$1" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//'
}

is_blank_or_comment_line() {
  local line="$1"

  [[ "$line" =~ ^[[:space:]]*($|#) ]]
}

strip_wrapping_quotes() {
  local value="$1"

  if [ "${value#\"}" != "$value" ] && [ "${value%\"}" != "$value" ]; then
    value="${value#\"}"
    value="${value%\"}"
  elif [ "${value#\'}" != "$value" ] && [ "${value%\'}" != "$value" ]; then
    value="${value#\'}"
    value="${value%\'}"
  fi

  printf '%s\n' "$value"
}

has_wrapping_quotes() {
  local value="$1"

  if [ "${value#\"}" != "$value" ] && [ "${value%\"}" != "$value" ]; then
    return 0
  fi

  if [ "${value#\'}" != "$value" ] && [ "${value%\'}" != "$value" ]; then
    return 0
  fi

  return 1
}

short_branch_name() {
  local branch="$1"
  local short_branch

  short_branch="$(printf '%s\n' "$branch" \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's#[^a-z0-9]+#_#g; s/^_+//; s/_+$//; s/_+/_/g' \
    | cut -c1-8 \
    | sed -E 's/^_+//; s/_+$//')"

  [ -n "$short_branch" ] || short_branch="wt"
  printf '%s\n' "$short_branch"
}

database_suffix_for_branch() {
  local branch="$1"

  printf '%s_%s\n' "$(short_branch_name "$branch")" "$(openssl rand -hex 3)"
}

env_file_value() {
  local env_file="$1"
  local env_name="$2"
  local line value

  [ -f "$env_file" ] || return 0

  while IFS= read -r line; do
    is_blank_or_comment_line "$line" && continue

    if [[ "$line" =~ ^[[:space:]]*(export[[:space:]]+)?${env_name}[[:space:]]*= ]]; then
      value="${line#*=}"
      value="$(trim "$value")"

      if ! has_wrapping_quotes "$value"; then
        value="$(printf '%s\n' "$value" | sed -E 's/[[:space:]]+#.*$//')"
        value="$(trim "$value")"
      fi

      strip_wrapping_quotes "$value"
      return 0
    fi
  done < "$env_file"
}

database_config_entries() {
  local config_file="$1"
  local line inner env_name default_value

  [ -f "$config_file" ] || return 0

  while IFS= read -r line; do
    is_blank_or_comment_line "$line" && continue

    case "$line" in
      *database:*ENV.fetch\(*)
        ;;
      *)
        continue
        ;;
    esac

    inner="${line#*ENV.fetch(}"
    inner="${inner%%)*}"

    env_name="${inner%%,*}"
    default_value=""
    if [ "$inner" != "$env_name" ]; then
      default_value="${inner#*,}"
    fi

    env_name="$(strip_wrapping_quotes "$(trim "$env_name")")"
    default_value="$(strip_wrapping_quotes "$(trim "$default_value")")"

    [ -n "$env_name" ] && printf '%s\t%s\n' "$env_name" "$default_value"
  done < "$config_file"
}

database_base_value() {
  local env_file="$1"
  local env_name="$2"
  local default_value="$3"
  local base_value

  base_value="$(env_file_value "$env_file" "$env_name")"
  if [ -n "$base_value" ]; then
    printf '%s\n' "$base_value"
    return 0
  fi

  printf '%s\n' "$default_value"
}

append_database_overrides() {
  local root="$1"
  local path="$2"
  local branch="$3"
  local config_file="$root/config/database.yml"
  local env_file="$root/.env.development"
  local env_local_file="$path/.env.local"
  local db_suffix wrote_header env_name default_value base_value seen_env_names

  [ -f "$config_file" ] || return 0

  db_suffix="$(database_suffix_for_branch "$branch")"
  wrote_header=0
  seen_env_names=$'\n'

  while IFS=$'\t' read -r env_name default_value; do
    [ -n "$env_name" ] || continue

    base_value="$(database_base_value "$env_file" "$env_name" "$default_value")"
    [ -n "$base_value" ] || continue

    case "$seen_env_names" in
      *$'\n'"$env_name"$'\n'*)
        continue
        ;;
    esac
    seen_env_names+="$env_name"$'\n'

    if [ "$wrote_header" -eq 0 ]; then
      if [ -f "$env_local_file" ] && [ -s "$env_local_file" ]; then
        printf '\n' >> "$env_local_file"
      fi
      printf '# database overrides\n' >> "$env_local_file"
      wrote_header=1
    fi

    printf '%s=%s_%s\n' "$env_name" "$base_value" "$db_suffix" >> "$env_local_file"
  done < <(database_config_entries "$config_file")
}

worktree_path_for_branch() {
  local branch="$1"

  git worktree list --porcelain \
    | awk -v b="refs/heads/${branch}" '
      $1 == "worktree" { p = $2 }
      $1 == "branch" && $2 == b { print p; exit }
    '
}

worktree_branch_entries() {
  git worktree list --porcelain \
    | awk '
      $1 == "worktree" { p = $2 }
      $1 == "branch" {
        b = $2
        sub("^refs/heads/", "", b)
        print b "\t" p
      }
    '
}

select_worktree_branch() {
  local prompt="$1"
  local current_branch selected

  current_branch="$(git branch --show-current 2>/dev/null || true)"

  selected="$(worktree_branch_entries \
    | awk -F '\t' -v current="$current_branch" '{
        marker = ($1 == current ? "*" : " ")
        printf "%s\t%s\t%s\n", marker, $1, $2
      }' \
    | fzf --prompt="$prompt" --delimiter=$'\t' --with-nth=1,2,3)" || return 1

  [ -n "$selected" ] || return 1
  printf '%s\n' "$selected" | cut -f2
}

cmd_add() {
  local branch="${1:-}"
  local default_branch
  default_branch="$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
    | sed 's#refs/remotes/origin/##')" || default_branch="main"
  local base="${2:-$default_branch}"
  [ -n "$branch" ] || die "usage: git wt add <branch> [base]"

  local root
  root="$(repo_root)"
  local path="$root/../${branch//\//-}"

  if [ -e "$path" ]; then
    die "target path already exists: $path"
  fi

  if ! git rev-parse --verify --quiet "${base}^{commit}" >/dev/null; then
    die "base branch not found: $base"
  fi

  if git show-ref --verify --quiet "refs/heads/$branch"; then
    git worktree add "$path" "$branch"
  else
    git worktree add -b "$branch" "$path" "$base"
  fi

  # copy over dev files (ignore if they don't exist)
  for f in certs .env.local; do
    if [ -e "$root/$f" ]; then
      cp -rn "$root/$f" "$path/"
    fi
  done

  append_database_overrides "$root" "$path" "$branch"

  echo "$path"
}

cmd_rm() {
  local branch="${1:-}"
  local path

  # interactive selection when no branch given
  if [ -z "$branch" ]; then
    command -v fzf >/dev/null || die "usage: git wt rm <branch> (install fzf for interactive selection)"
    branch="$(select_worktree_branch 'remove worktree> ')" || return 0
  fi

  [ -n "$branch" ] || return 0

  path="$(worktree_path_for_branch "$branch")"
  [ -n "$path" ] || die "no worktree found for branch '$branch'"

  git worktree remove "$path"
}


cmd_ls() {
  git worktree list
}

cmd_prune() {
  git worktree prune -v
}

cmd_path() {
  local branch="${1:-}"
  [ -n "$branch" ] || die "usage: git wt path <branch>"

  local path
  path="$(worktree_path_for_branch "$branch")"
  [ -n "$path" ] || die "no worktree found for branch '$branch'"
  echo "$path"
}

cmd_sw() {
  local branch="${1:-}"

  if [ -z "$branch" ]; then
    command -v fzf >/dev/null || die "usage: git wt sw <branch> (install fzf for interactive selection)"
    branch="$(select_worktree_branch 'switch worktree> ')" || return 0
  fi

  [ -n "$branch" ] || return 0
  cmd_path "$branch"
}

case "${1:-}" in
  add)   shift; cmd_add "$@" ;;
  sw|switch) shift; cmd_sw "$@" ;;
  rm)    shift; cmd_rm "$@" ;;
  ls)    shift; cmd_ls ;;
  prune) shift; cmd_prune ;;
  path)  shift; cmd_path "$@" ;;
  *)     die "usage: git wt {add|sw|rm|ls|prune|path}" ;;
esac
